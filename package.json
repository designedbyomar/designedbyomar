{
  "name": "designedbyomar",
  "version": "1.1.1",
  "private": true,
  "description": "Portfolio site for Omar Tavarez — product design for AI workflows, design systems, fintech, healthcare SaaS, and enterprise product strategy.",
  "homepage": "https://designedbyomar.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/designedbyomar/designedbyomar.git"
  },
  "bugs": {
    "url": "https://github.com/designedbyomar/designedbyomar/issues"
  },
  "author": "Omar Tavarez <omar@designedbyomar.com> (https://designedbyomar.com)",
  "license": "MIT",
  "keywords": [
    "portfolio",
    "product-design",
    "design-systems",
    "ai-workflows",
    "fintech",
    "healthcare-saas",
    "enterprise-ux",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node postbuild.js",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test:build && npm run test:seo && playwright test",
    "test:build": "npm run build",
    "test:seo": "node --test tests/seo-static.test.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "optimize:image": "node scripts/optimize-image.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.50.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.16"
  }
}
